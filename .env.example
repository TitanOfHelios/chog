# ============================================================
# THE 7 SECONDS CHOG — TEK .ENV DOSYASI
#
# Hem sunucu (server/) hem istemci (client/) AYNI dosyayı okur.
# Kullanmak için:
#   1) Bu dosyayı ".env" olarak kopyalayın:  cp .env.example .env
#   2) Aşağıdaki değerleri istediğiniz gibi değiştirin.
#   3) "npm run dev"i (yeniden) başlatın — .env sadece açılışta okunur,
#      değişiklikten sonra sunucuyu/vite'ı yeniden başlatmanız gerekir.
#
# İstemci (tarayıcıda çalışan) tarafa giden her değişkenin adı "VITE_"
# ile başlar — Vite sadece bu önekle başlayanları tarayıcıya aktarır.
# Önek taşımayanlar (PORT, ARENA_RADIUS, ...) sadece sunucu tarafından
# okunur.
# ============================================================

# ---------------- SUNUCU ----------------

# Sunucunun dinleyeceği port. Barındırma servisi (Render/Railway vb.)
# genelde kendi PORT değerini otomatik enjekte eder.
PORT=8080

# Hareket alanının yarıçapı — SADECE özel bir island.glb YÜKLENMEMİŞSE
# kullanılan prosedürel arazi için geçerlidir. island.glb varsa client
# bunun yerine adanın gerçek sınırlarını kullanır.
ARENA_RADIUS=85

# Paranın kaç ms sonra yeniden doğacağı (varsayılan 7000 = 7 saniye)
COIN_CYCLE_MS=7000

# Sunucunun oyun durumunu ne sıklıkla yayınladığı (ms)
TICK_MS=100

# Bağlı ama yanıt vermeyen (kopan) bağlantıları temizleme süresi (ms)
HEARTBEAT_MS=15000


# ---------------- İSTEMCİ: SUNUCU ADRESİ ----------------

# Oyunun bağlanacağı WebSocket adresi.
# - Sunucu ve tarayıcı AYNI bilgisayardaysa: ws://localhost:8080
# - Telefondan/başka bir cihazdan test ediyorsanız: bilgisayarınızın
#   yerel ağ IP'sini yazın, örn. ws://192.168.1.11:8080
#   (IP'yi öğrenmek için: Windows'ta "ipconfig", Mac/Linux'ta "ifconfig")
# - İnternete açık bir sunucuya (Render/Railway vb.) yüklediyseniz onun
#   verdiği wss://... adresini yazın.
VITE_WS_URL=ws://localhost:8080


# ---------------- İSTEMCİ: 3D MODEL DOSYA YOLLARI ----------------

# Hepsi client/public/ klasörüne göre yazılır. Dosya yoksa/bozuksa oyun
# otomatik olarak basit bir yer tutucuya geri döner — çökmez. Modelinizin
# adını/klasörünü değiştirdiyseniz burayı güncellemeniz yeterli, kod
# tarafında hiçbir şey değiştirmenize gerek yok.
VITE_CHARACTER_MODEL_PATH=/assets/character.glb
VITE_COIN_MODEL_PATH=/assets/coin.glb
VITE_ISLAND_MODEL_PATH=/assets/island.glb

# Ortadaki heykel(ler) — character.glb/coin.glb ile aynı mantıkta,
# client/public/assets içine koyduğunuz .glb dosyalarından yüklenir.
# Dosya yoksa/bozuksa otomatik olarak basit/renksiz bir yedek heykele
# geri dönülür, oyun çökmez.
VITE_STATUE_MODEL_PATH=/assets/statue.glb
# İkinci heykel: birincinin hemen yanında durur, ayrı bir .glb dosyasından.
VITE_STATUE2_MODEL_PATH=/assets/statue2.glb

# Heykelin altına basit/renksiz bir sütun (kaide) eklenir, model bu
# sütunun tam üstüne oturacak şekilde yukarı kaldırılır. Kapatmak
# isterseniz false yapın (model doğrudan yere oturur).
VITE_STATUE_PEDESTAL_ENABLED=true
VITE_STATUE_PEDESTAL_HEIGHT=0.9
VITE_STATUE_PEDESTAL_RADIUS=0.4
VITE_STATUE_PEDESTAL_COLOR=#9a958c

# İsim plakası TEK bir dosya değildir: bu klasördeki manifest.json'da
# listelenen .glb dosyalarından oyuncu login ekranında istediğini SEÇER.
# Yeni plaka eklemek için: .glb dosyasını bu klasöre koyup
# client/public/assets/plate/manifest.json'a bir satır ekleyin (bkz. o
# klasördeki README.md). manifest.json boşsa (hiç plaka yoksa) seçim
# ekranı görünmez, isimler sade yazı etiketiyle gösterilir.
VITE_PLATE_FOLDER=/assets/plate/


# ---------------- İSTEMCİ: BOYUT AYARLARI ----------------

# Karakter modelinin oyun içindeki hedef boyu (birim, ör. "insan boyu")
VITE_CHARACTER_HEIGHT=1.3

# Para (coin) modelinin oyun içindeki hedef yüksekliği (birim)
VITE_COIN_HEIGHT=0.55

# İsim plakasının isme göre otomatik uzayıp kısalacağı genişlik aralığı
# (birim) ve her karakter için eklenen genişlik. Plaka bu sınırların
# dışına çıkmaz, sadece aralık içinde isme göre gerilir.
VITE_PLATE_MIN_WIDTH=1.1
VITE_PLATE_MAX_WIDTH=3.4
VITE_PLATE_WIDTH_PER_CHAR=0.16


# ---------------- İSTEMCİ: HAREKET / FİZİK ----------------

# Yürüme hızı (birim/saniye, HIZLAN basılı değilken)
VITE_MOVE_SPEED=4.2

# Klavyeyle (A/D) döndürme hızı (radyan/saniye, tam basınçta)
VITE_TURN_SPEED=3.0

# Zıplama başlangıç hızı ve yerçekimi (birim/saniye, birim/saniye²)
VITE_JUMP_VELOCITY=6.2
VITE_GRAVITY=-16

# HIZLAN: basılı tuttukça hız kademeli artar. MULT = en yüksek çarpan,
# RAMP_TIME = tam hıza ulaşma süresi (saniye), DECAY_RATE = bırakınca
# ne kadar hızlı normale döneceği.
VITE_SPRINT_MAX_MULT=2.8
VITE_SPRINT_RAMP_TIME=2.0
VITE_SPRINT_DECAY_RATE=1.6


# ---------------- İSTEMCİ: KAMERA ----------------

# Kameranın karaktere başlangıç uzaklığı ve yakınlaşma/uzaklaşma sınırları
VITE_CAMERA_DISTANCE=7
VITE_CAMERA_DISTANCE_MIN=3
VITE_CAMERA_DISTANCE_MAX=16

# Kameranın başlangıç dikey açısı (radyan; küçük = alçak, büyük = kuşbakışı)
VITE_CAMERA_PITCH=0.38


# ---------------- İSTEMCİ: JOYSTICK ----------------

# Joystick'in ortasındaki, girdi olarak sayılmayan "ölü bölge" (0-1 arası;
# 0 = her ufak dokunuş girdi sayılır, 0.2 = ortada geniş bir tolerans olur)
VITE_JOYSTICK_DEADZONE=0.1


# ---------------- İSTEMCİ: ORTADAKİ HEYKEL(LER) ----------------

# Haritanın ortasında duran heykeller. Kapatmak isterseniz false yapın
# (ikisi de kapanır).
VITE_STATUE_ENABLED=true
# .glb dosyaları bulunamazsa kullanılan yedek heykelin rengi (hex).
# Kasıtlı olarak nötr/gri bırakılmıştır ("renksiz" görünüm).
VITE_STATUE_COLOR=#b7b3ad
# Boyut çarpanı (1 = normal, 1.5 = %50 daha büyük)
VITE_STATUE_SCALE=1
# .glb yüklendiğinde otomatik ölçekleneceği hedef yükseklik (birim)
VITE_STATUE_HEIGHT=2.3
# İkinci heykelin, birincisine göre X/Z ofseti (birim)
VITE_STATUE2_OFFSET_X=3.2
VITE_STATUE2_OFFSET_Z=0


# ---------------- İSTEMCİ: CREDIT / YAPIMCI BİLGİSİ ----------------

# Giriş ekranının altında küçük ve sade şekilde gösterilir. Boş
# bırakılırsa hiç görünmez.
VITE_CREDITS_TEXT=
# Credit metni tıklanabilir bir bağlantı olsun isterseniz (opsiyonel)
VITE_CREDITS_URL=
