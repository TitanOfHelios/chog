# Giriş ekranındaki "Sunucu adresi" alanının varsayılan değeri.
# Sunucuyu kendi bilgisayarınızda çalıştırıyorsanız değiştirmeyin.
# İnternete açık bir sunucuya (Render/Railway vb.) yüklediyseniz onun
# verdiği wss://... adresini buraya yazın.
VITE_WS_URL=ws://localhost:8080

# Karakter modelinin oyun içindeki hedef boyu (birim)
VITE_CHARACTER_HEIGHT=1.3
