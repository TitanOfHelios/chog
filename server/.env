# Sunucunun dinleyeceği port. Barındırma servisi (Render/Railway vb.)
# genelde kendi PORT değerini otomatik enjekte eder; boş bırakabilirsiniz.
PORT=8080

# Hareket alanının yarıçapı (özel ada modeli yüklenmemişse kullanılan
# prosedürel arazi için). Ada modeli varsa client bunun yerine adanın
# gerçek sınırlarını kullanır.
ARENA_RADIUS=85

# Paranın kaç ms sonra yeniden doğacağı (7 saniye)
COIN_CYCLE_MS=7000

# Sunucu durum yayını sıklığı (ms)
TICK_MS=100

# Bağlı ama yanıt vermeyen (kopan) soketleri temizleme süresi (ms)
HEARTBEAT_MS=15000
